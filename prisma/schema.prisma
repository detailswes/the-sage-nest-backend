generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      Int                       @id @default(autoincrement())
  email                   String                    @unique
  password_hash           String?
  role                    Role                      @default(EXPERT)
  created_at              DateTime                  @default(now())
  name                    String                    @default("Unknown")
  is_verified             Boolean                   @default(true)
  verification_code       String?
  verification_expires_at DateTime?
  reset_token             String?
  reset_token_expires_at  DateTime?
  account_deleted         Boolean                   @default(false)
  locked_until            DateTime?
  login_attempts          Int                       @default(0)
  phone                   String?
  two_factor_enabled      Boolean                   @default(false)
  otp_hash                String?
  otp_expires_at          DateTime?
  otp_attempts            Int                       @default(0)
  parent_status           ParentStatus?
  bookings_as_parent      Booking[]                 @relation("ParentBookings")
  expert                  Expert?
  notifications           Notification[]
  oauth_accounts          OAuthAccount[]
  pp_acceptances          PrivacyPolicyAcceptance[]
  refreshTokens           RefreshToken[]
  reviews_as_parent       Review[]                  @relation("ParentReviews")
  saved_experts           SavedExpert[]             @relation("ParentSavedExperts")
  tc_acceptances          TcAcceptance[]
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  token      String   @unique
  user_id    Int
  expires_at DateTime
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model OAuthAccount {
  id          Int           @id @default(autoincrement())
  user_id     Int
  provider    OAuthProvider
  provider_id String
  created_at  DateTime      @default(now())
  user        User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, provider_id])
}

model Expert {
  id                         Int                 @id @default(autoincrement())
  user_id                    Int                 @unique
  bio                        String?
  profile_image              String?
  expertise                  String?
  stripe_account_id          String?
  status                     ExpertStatus        @default(PENDING)
  address_city               String?
  address_postcode           String?
  address_street             String?
  languages                  String[]            @default([])
  position                   String?
  session_format             SessionFormat?
  summary                    String?
  timezone                   String              @default("Europe/Rome")
  facebook                   String?
  instagram                  String?
  linkedin                   String?
  stripe_onboarding_complete Boolean             @default(false)
  change_request_note        String?
  change_requested_at        DateTime?
  is_published               Boolean             @default(true)
  pending_languages          String[]            @default([])
  advance_booking_days       Int                 @default(60)
  buffer_minutes             Int                 @default(0)
  min_notice_hours           Int                 @default(24)
  notify_cancellation        Boolean             @default(true)
  notify_new_booking         Boolean             @default(true)
  notify_reminder            Boolean             @default(true)
  availability               Availability[]
  blockouts                  AvailabilityBlock[]
  bookings                   Booking[]           @relation("ExpertBookings")
  business_info              BusinessInfo?
  certifications             Certification[]
  user                       User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  insurance                  Insurance?
  qualifications             Qualification[]
  reviews                    Review[]
  saved_by                   SavedExpert[]
  services                   Service[]
  profile_draft              ExpertProfileDraft?
}

model Service {
  id               Int             @id @default(autoincrement())
  expert_id        Int
  title            String
  duration_minutes Int
  price            Decimal         @db.Decimal(10, 2)
  is_active        Boolean         @default(true)
  cluster          ServiceCluster?
  description      String?
  format           ServiceFormat?
  sort_order       Int             @default(0)
  bookings         Booking[]
  expert           Expert          @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Qualification {
  id           Int               @id @default(autoincrement())
  expert_id    Int
  type         QualificationType
  custom_name  String?
  document_url String?
  created_at   DateTime          @default(now())
  expert       Expert            @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Certification {
  id           Int      @id @default(autoincrement())
  expert_id    Int
  name         String
  document_url String?
  created_at   DateTime @default(now())
  expert       Expert   @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Insurance {
  id                Int      @id @default(autoincrement())
  expert_id         Int      @unique
  document_url      String
  policy_expires_at DateTime
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt
  expert            Expert   @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model BusinessInfo {
  id                 Int        @id @default(autoincrement())
  expert_id          Int        @unique
  entity_type        EntityType
  legal_name         String
  date_of_birth      DateTime?
  primary_address    String
  tin                String
  vat_number         String?
  company_reg_number String?
  iban               String
  business_email     String
  website            String
  municipality       String?
  business_address   String?
  created_at         DateTime   @default(now())
  updated_at         DateTime   @updatedAt
  expert             Expert     @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Availability {
  id          Int    @id @default(autoincrement())
  expert_id   Int
  day_of_week Int
  start_time  String
  end_time    String
  expert      Expert @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model AvailabilityBlock {
  id         Int      @id @default(autoincrement())
  expert_id  Int
  date       DateTime @db.Date
  start_time String?
  end_time   String?
  created_at DateTime @default(now())
  expert     Expert   @relation(fields: [expert_id], references: [id], onDelete: Cascade)
}

model Booking {
  id                       Int            @id @default(autoincrement())
  expert_id                Int
  parent_id                Int
  service_id               Int
  scheduled_at             DateTime
  duration_minutes         Int
  format                   ServiceFormat
  status                   BookingStatus  @default(PENDING_PAYMENT)
  session_link_sent        Boolean        @default(false)
  created_at               DateTime       @default(now())
  updated_at               DateTime       @updatedAt
  amount                   Decimal?       @db.Decimal(10, 2)
  cancellation_reason      String?
  cancelled_at             DateTime?
  platform_fee             Decimal?       @db.Decimal(10, 2)
  reminder_1h_sent         Boolean        @default(false)
  reminder_24h_sent        Boolean        @default(false)
  rescheduled_at           DateTime?
  rescheduled_from_id      Int?
  stripe_charge_id         String?
  stripe_payment_intent_id String?
  stripe_transfer_id       String?
  transfer_attempts        Int            @default(0)
  transfer_due_at          DateTime?
  transfer_status          String?
  stripe_refund_id         String?
  refund_status            String?
  refund_amount            Decimal?       @db.Decimal(10, 2)
  dispute_reason           String?
  disputed_at              DateTime?
  internal_admin_note      String?
  is_disputed              Boolean        @default(false)
  is_reschedule            Boolean        @default(false)
  expert                   Expert         @relation("ExpertBookings", fields: [expert_id], references: [id], onDelete: Cascade)
  parent                   User           @relation("ParentBookings", fields: [parent_id], references: [id], onDelete: Cascade)
  rescheduled_from         Booking?       @relation("BookingReschedule", fields: [rescheduled_from_id], references: [id])
  rescheduled_to           Booking[]      @relation("BookingReschedule")
  service                  Service        @relation(fields: [service_id], references: [id], onDelete: Cascade)
  notifications            Notification[]
  review                   Review?
  tc_acceptance            TcAcceptance?

  @@unique([expert_id, scheduled_at])
}

model LegalDocument {
  id             Int      @id @default(autoincrement())
  type           String
  version        String
  effective_from DateTime @default(now())

  @@unique([type, version])
}

model PrivacyPolicyAcceptance {
  id                    Int       @id @default(autoincrement())
  user_id               Int
  version               String
  accepted_at           DateTime  @default(now())
  marketing_consent     Boolean   @default(false)
  marketing_accepted_at DateTime?
  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model TcAcceptance {
  id          Int      @id @default(autoincrement())
  user_id     Int
  booking_id  Int      @unique
  version     String
  accepted_at DateTime @default(now())
  booking     Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model AdminAuditLog {
  id          Int      @id @default(autoincrement())
  admin_id    Int
  action      String
  entity_type String
  entity_id   Int
  note        String?
  created_at  DateTime @default(now())
}

model StripeEvent {
  id              Int      @id @default(autoincrement())
  stripe_event_id String   @unique
  processed_at    DateTime @default(now())
}

model SavedExpert {
  id        Int      @id @default(autoincrement())
  parent_id Int
  expert_id Int
  saved_at  DateTime @default(now())
  expert    Expert   @relation(fields: [expert_id], references: [id], onDelete: Cascade)
  parent    User     @relation("ParentSavedExperts", fields: [parent_id], references: [id], onDelete: Cascade)

  @@unique([parent_id, expert_id])
}

model Review {
  id         Int      @id @default(autoincrement())
  booking_id Int      @unique
  parent_id  Int
  expert_id  Int
  rating     Int
  comment    String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  booking    Booking  @relation(fields: [booking_id], references: [id], onDelete: Cascade)
  expert     Expert   @relation(fields: [expert_id], references: [id], onDelete: Cascade)
  parent     User     @relation("ParentReviews", fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([expert_id])
}

model Notification {
  id         Int              @id @default(autoincrement())
  user_id    Int
  type       NotificationType
  title      String
  body       String
  is_read    Boolean          @default(false)
  booking_id Int?
  created_at DateTime         @default(now())
  booking    Booking?         @relation(fields: [booking_id], references: [id])
  user       User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

enum Role {
  EXPERT
  ADMIN
  PARENT
}

enum ExpertStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  CHANGES_REQUESTED
}

enum ParentStatus {
  ACTIVE
  DEACTIVATED
  SUSPENDED
}

enum SessionFormat {
  ONLINE
  IN_PERSON
  BOTH
}

enum ServiceFormat {
  ONLINE
  IN_PERSON
}

enum ServiceCluster {
  FOR_PARENTS
  FOR_BABY
  PACKAGE
  GIFT
  EVENT
}

enum QualificationType {
  LACTATION_CONSULTANT
  BREASTFEEDING_COUNSELLOR
  INFANT_SLEEP_CONSULTANT
  DOULA
  MIDWIFE
  BABY_OSTEOPATH
  PAEDIATRIC_NUTRITIONIST
  EARLY_YEARS_SPECIALIST
  POSTNATAL_PHYSIOTHERAPIST
  PARENTING_COACH
  OTHER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  PENDING_PAYMENT
  REFUNDED
}

enum EntityType {
  INDIVIDUAL
  COMPANY
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_RESCHEDULED
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
  BOOKING_REMINDER
  EXPERT_APPROVED
  EXPERT_REJECTED
}

enum DraftStatus {
  PENDING_REVIEW
  REJECTED
}

model ExpertProfileDraft {
  id               Int            @id @default(autoincrement())
  expert_id        Int            @unique
  expert           Expert         @relation(fields: [expert_id], references: [id], onDelete: Cascade)
  bio              String?
  summary          String?
  position         String?
  session_format   SessionFormat?
  address_street   String?
  address_city     String?
  address_postcode String?
  languages        String[]       @default([])
  pending_languages String[]      @default([])
  timezone         String?
  instagram        String?
  facebook         String?
  linkedin         String?
  expertise        String?
  status           DraftStatus    @default(PENDING_REVIEW)
  submitted_at     DateTime       @default(now())
  reviewed_at      DateTime?
  rejection_note   String?

  @@map("expert_profile_drafts")
}
